# ─────────────────────────────────────────────────────────────────────────────
# Practice switcher treatment
# ─────────────────────────────────────────────────────────────────────────────
# BUILD-TIME ONLY — read by vite.config.ts at build time and compiled into the
# bundle as a string literal. Changing this value requires a rebuild + redeploy.
# This is NOT a user-facing setting and must NOT be surfaced in the Settings UI.
#
# Values:
#   A  (default, or unset)  — text-only pills (HRV · Stretch · Navi)
#   B                       — inline SVG glyph + label per pill (theme-token colors)
#
# Any value other than 'B' compiles to treatment A (fail-safe default, D-07).
VITE_SWITCHER_TREATMENT=A
